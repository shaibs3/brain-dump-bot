# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
OPENAI_API_KEY=your_openai_api_key
ALLOWED_USER_ID=your_telegram_user_id  # Get from @userinfobot on Telegram

# Optional - Defaults shown
SUMMARY_TIME=21:00
TIMEZONE=UTC

# Language for speech recognition (e.g., "en-US", "he-IL", "es-ES", "de-DE")
# Full list: https://cloud.google.com/speech-to-text/docs/languages
# LANGUAGE_CODE=en-US

# Custom categories (format: "Name:emoji,Name:emoji,...")
# Default: Career:💼,Health:🏥,Fitness:💪,Relationships:👥,Finance:💰,Learning:📚,Projects:🔧,Shopping:🛒,Home:🏠
# CATEGORIES=Career:💼,Health:🏥,Fitness:💪,Relationships:👥,Finance:💰,Learning:📚,Projects:🔧,Shopping:🛒,Home:🏠

# Optional - Todoist Integration
# Get token from: https://todoist.com/app/settings/integrations/developer
# TODOIST_API_TOKEN=your_todoist_api_token
# TODOIST_PROJECT_NAME=Brain Dump
