# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
ALLOWED_USER_ID=your_telegram_user_id  # Get from @userinfobot on Telegram

# LLM Provider - choose "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key

# Gemini (required if LLM_PROVIDER=gemini) - Free tier available!
# Get key from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key

# Optional - Override default model (gpt-4o-mini for OpenAI, gemini-3-flash-preview for Gemini)
# LLM_MODEL=gpt-4o

# Optional - Defaults shown
SUMMARY_TIME=21:00
TIMEZONE=UTC

# Language for speech recognition (e.g., "en-US", "he-IL", "es-ES", "de-DE")
# Full list: https://cloud.google.com/speech-to-text/docs/languages
# LANGUAGE_CODE=en-US

# Custom categories (format: "Name:emoji,Name:emoji,...")
# Default: Career:💼,Health:🏥,Fitness:💪,Relationships:👥,Finance:💰,Learning:📚,Projects:🔧,Shopping:🛒,Home:🏠,Books:📖
# CATEGORIES=Career:💼,Health:🏥,Fitness:💪,Relationships:👥,Finance:💰,Learning:📚,Projects:🔧,Shopping:🛒,Home:🏠,Books:📖

# Optional - Todoist Integration
# Get token from: https://todoist.com/app/settings/integrations/developer
# TODOIST_API_TOKEN=your_todoist_api_token
# TODOIST_PROJECT_NAME=Brain Dump
